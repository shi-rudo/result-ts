{
  "name": "@shirudo/result",
  "version": "1.0.0",
  "description": "Robust, type-safe error handling for TypeScript using the Result pattern (Monad)",
  "type": "module",
  "private": false,
  "packageManager": "pnpm@10.32.1",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "result",
    "monad",
    "error-handling",
    "typescript",
    "functional-programming",
    "either",
    "option",
    "maybe",
    "type-safe",
    "pipe",
    "async"
  ],
  "author": "shirudo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shi-rudo/result-ts.git"
  },
  "bugs": {
    "url": "https://github.com/shi-rudo/result-ts/issues"
  },
  "homepage": "https://github.com/shi-rudo/result-ts#readme",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "typecheck": "tsc --noEmit --emitDeclarationOnly false",
    "test:types": "tsc -p tsconfig.type-tests.json --noEmit --emitDeclarationOnly false",
    "lint": "tsc --noEmit --emitDeclarationOnly false",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "prebuild": "pnpm lint && pnpm test:types && pnpm test run",
    "build": "tsdown",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "@types/node": "^25.0.2",
    "@vitest/coverage-v8": "^4.0.15",
    "fast-check": "^4.8.0",
    "tsdown": "^0.17.4",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vitest": "^4.0.15"
  }
}
